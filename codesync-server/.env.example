PORT=3000

# CORS origins (comma-separated). Use * to allow all (not recommended for production).
CORS_ORIGIN=http://localhost:5173

# Example for production:
# CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com

# Redis URL for shared room/user state (required).
# Format: redis://[username:password@]host[:port][/db]
# Local:        redis://localhost:6379
# Upstash/TLS:  rediss://default:password@host:port
REDIS_URL=redis://localhost:6379
