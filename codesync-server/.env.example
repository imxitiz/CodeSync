PORT=3000

# CORS origins (comma-separated). Use * to allow all (not recommended for production).
CORS_ORIGIN=http://localhost:5173

# Owner-reclaim secret — REQUIRED in production.
# Used to sign HMAC tokens that let the original room owner reclaim creator
# rights after an accidental disconnect. Tokens are bound to room + username
# + join timestamp and cannot be forged without this secret.
#
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CODESYNC_OWNER_SECRET=change-me-to-random-64-hex-chars

# Example for production:
# CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com
