{
  "name": "codesync-socketio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:front": "vite",
    "dev:server": "bun --watch codesync-server/src/index.ts",
    "dev": "vite-react-ssg build && bun codesync-server/src/index.ts",
    "build": "vite-react-ssg build",
    "build:ssg": "vite-react-ssg build",
    "server": "bun codesync-server/src/index.ts",
    "preview": "vite preview",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "type-check": "tsc --noEmit",
    "lint": "ultracite check .",
    "format": "ultracite format --write ."
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/codemirror": "^5.60.17",
    "@types/randomcolor": "^0.5.9",
    "@uiw/codemirror-theme-dracula": "^4.25.10",
    "@uiw/codemirror-theme-okaidia": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "radix-ui": "^1.6.0",
    "randomcolor": "^0.6.2",
    "react": "^19.2.7",
    "react-avatar": "^5.0.4",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.4",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "uuid": "^11.1.1",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "globals": "^15.15.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-react-ssg": "^0.9.1-beta.1"
  }
