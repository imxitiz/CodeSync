# ── Frontend ────────────────────────────────────────────────────────
# Backend API URL for the frontend to connect to
# For local development
VITE_BACKEND_API_URL=http://localhost:3000

# For production (Render backend)
# VITE_BACKEND_API_URL=https://your-app-name.onrender.com

# ── Backend (codesync-server/) ─────────────────────────────────────
# These are used by codesync-server/.env — see codesync-server/.env.example
# for full documentation including CODESYNC_OWNER_SECRET.
#
# CORS Origins for the backend
# For production, set this to your frontend URL
# For multiple origins, separate with commas
# Use * to allow all origins (NOT recommended for production)
CORS_ORIGIN=http://localhost:5173

# Example for production
# CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com
